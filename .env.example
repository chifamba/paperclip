# Database configuration
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=paperclip
POSTGRES_DB=paperclip
DATABASE_URL=postgres://paperclip:paperclip@db:5432/paperclip

# Auth configuration (IMPORTANT: Change these for production/LAN use)
# PAPERCLIP_PUBLIC_URL must match the address you use in your browser (e.g., http://mypc.local)
PAPERCLIP_PUBLIC_URL=http://localhost:80
BETTER_AUTH_SECRET=paperclip-dev-secret-change-me-1234567890

# API Keys (optional, for local adapter support)
# ANTHROPIC_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Deployment settings
FRONTEND_PORT=80
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
